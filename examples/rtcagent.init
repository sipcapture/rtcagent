#!/bin/sh
### BEGIN INIT INFO
# Provides: rtcagent
# Required-Start:	$syslog $local_fs $remote_fs $network
# Required-Stop:	$syslog $local_fs $remote_fs $network
# Default-Start:	2 3 4 5
# Default-Stop:		0 1 6
# Short-Description: RTCagent eBPF HEP capture
### END INIT INFO

. /lib/lsb/init-functions
prog=rtcagent
PIDFILE=/var/run/$prog.pid
ENV_FILE=/usr/local/rtcagent/etc/rtcagent.env
DESC="RTCagent eBPF HEP capture"

start() {
	[ -r "$ENV_FILE" ] && . "$ENV_FILE"
	log_daemon_msg "Starting $DESC" "$prog"
	start_daemon -p $PIDFILE /usr/local/rtcagent/bin/rtcagent \
		"${RTCAGENT_MODE:-kamailio}" \
		-m "${RTCAGENT_APP_PATH:-/usr/sbin/kamailio}" \
		--hep-server="${HEP_SERVER:-127.0.0.1}" \
		--hep-port="${HEP_PORT:-9060}" \
		--hep-transport="${HEP_TRANSPORT:-udp}"
	if [ $? -ne 0 ]; then
		log_end_msg 1
		exit 1
	fi
	log_end_msg 0
}

stop() {
	log_daemon_msg "Stopping $DESC" "$prog"
	killproc -p $PIDFILE /usr/local/rtcagent/bin/rtcagent
	if [ $? -ne 0 ]; then
		log_end_msg 1
		exit 1
	fi
	log_end_msg 0
}

case "$1" in
	start) start ;;
	stop) stop ;;
	restart) stop; start ;;
	status) status_of_proc -p $PIDFILE /usr/local/rtcagent/bin/rtcagent "$DESC" ;;
	*) echo "Usage: $0 {start|stop|restart|status}"; exit 1 ;;
esac

exit 0
